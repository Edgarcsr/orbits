{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "drizzle-kit generate --config=apps/api/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=apps/api/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=apps/api/drizzle.config.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.6.2",
    "turbo": "^2.8.15",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
